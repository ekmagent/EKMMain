# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# screaming frog crawl exports (large CSV files, local only)
/screaming-frog-reports/

# CSG carrier probes — commercially-licensed rate data; derived content only goes on pages
/artifacts/csg-probes/

# Local pack rank tracker results — competitive intel snapshots, can grow large
/artifacts/local-pack/

# CSG auth token cache — credential, never commit
/scripts/.csg-token.json

# Client rate reports + one-off quote scripts — contain client names/DOBs/ZIPs; repo is public
/artifacts/csg-reports/
/scripts/csg-debbie-08034.js
/scripts/csg-couple-quote.js

# Parasite SEO drafts — internal working copy, not site content
/artifacts/parasite-drafts/
